import random

cards = [11, 2, 3, 4, 5, 6, 7, 8, 9, 10, 10, 10, 10]

def draw():
    return random.choice(cards)

def calc(cards):
    while 11 in cards and sum(cards) > 21:
        cards.remove(11)
        cards.append(1)

    if sum(cards) == 21 and len(cards) == 2:
        return 1

    if sum(cards) > 21:
        return 0

    return sum(cards)

def compare(user_score, dealer_score):

    if user_score == dealer_score:
        return "Draw!"

    elif user_score == 1:
        return "You won with blackjack!"

    elif dealer_score == 1:
        return "Dealer won with blackjack!"

    elif user_score == 0:
        return "You went over. You lose!"

    elif dealer_score == 0:
        return "Dealer went over. You win!"

    elif user_score > dealer_score:
        return "You win!"

    else:
        return "You lose!"

def gameplay():
    print("\n--- Welcome to Blackjack ---")

    user_cards = []
    dealer_cards = []
    game_over = False

    for i in range(2):
        user_cards.append(draw())
        dealer_cards.append(draw())

    while not game_over:
        user_score = calc(user_cards)
        dealer_score = calc(dealer_cards)

        print(f"Your cards: {user_cards}, current score: {user_score}")
        print(f"Dealer's first card: {dealer_cards[0]}")

        if user_score == 0 or dealer_score == 0:
            game_over = True
        else:
            user_should_deal = input(
                "Type 'y' to get another card, type 'n' to stand: "
            ).lower()

            if user_should_deal == 'y':
                user_cards.append(draw())
            else:
                game_over = True

    while dealer_score != 0 and dealer_score < 17:
        dealer_cards.append(draw())
        dealer_score = calc(dealer_cards)

    user_score = calc(user_cards)
    dealer_score = calc(dealer_cards)

    print(f"\nYour final hand: {user_cards}, final score: {user_score}")
    print(f"Dealer's final hand: {dealer_cards}, final score: {dealer_score}")

    print(compare(user_score, dealer_score))

gameplay()
